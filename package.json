{
  "name": "mythosnote-frontend",
  "version": "1.0.0",
  "description": "Frontend for MythosNote - AI-powered note-taking application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build:css": "./node_modules/.bin/tailwindcss -i ./static/css/input.css -o ./static/css/output.css",
    "watch:css": "./node_modules/.bin/tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "dev": "npm run watch:css",
    "build": "npm run build:css"
  },
  "keywords": [
    "ai",
    "note-taking",
    "document",
    "search",
    "tailwind"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.17",
    "eslint": "^10.4.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.33",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "aos": "^2.3.4",
    "marked": "^11.1.1",
    "mermaid": "^10.6.1"
  }
}
