{
  "name": "mythosnote-frontend",
  "version": "1.0.0",
  "description": "Frontend for MythosNote - AI-powered note-taking application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css",
    "watch:css": "tailwindcss -i ./static/css/input.css -o ./static/css/output.css --watch",
    "dev": "npm run watch:css",
    "build": "npm run build:css"
  },
  "keywords": [
    "ai",
    "note-taking",
    "document",
    "search",
    "tailwind"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1"
  },
  "dependencies": {
    "flowbite": "^2.0.0",
    "marked": "^11.1.1",
    "mermaid": "^10.6.1"
  }
}
